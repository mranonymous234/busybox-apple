#
# BusyBox Minimal Configuration (CI / iOS-style toolset)
#

CONFIG_STATIC=y

#
# Core utilities only
#
CONFIG_CAT=y
CONFIG_ECHO=y
CONFIG_LS=y
CONFIG_CP=y
CONFIG_MV=y
CONFIG_RM=y
CONFIG_MKDIR=y
CONFIG_TOUCH=y
CONFIG_PWD=y
CONFIG_FIND=y
CONFIG_GREP=y

#
# Shell (optional but harmless for testing)
#
CONFIG_SH_IS_NONE=y

#
# Disable login/utmp/wtmp (IMPORTANT FIX for utmp.h error)
#
# These are what break iOS / cross builds
#
# CONFIG_FEATURE_UTMP is not set
# CONFIG_FEATURE_WTMP is not set
# CONFIG_FEATURE_LAST_SMALL is not set

#
# Disable SUID system (avoids macOS/Linux permission features)
#
CONFIG_FEATURE_SUID=n
CONFIG_FEATURE_SUID_CONFIG=n

#
# Disable PAM / shadow / login system
#
CONFIG_PAM=n
CONFIG_USE_BB_PWD_GRP=y
CONFIG_FEATURE_SHADOWPASSWDS=n

#
# Reduce system dependencies
#
CONFIG_INSTALL_NO_USR=y
CONFIG_FEATURE_CLEAN_UP=n

#
# Build system safety
#
CONFIG_PLATFORM_LINUX=y
CONFIG_LFS=y

#
# Avoid interactive configs in CI
#
CONFIG_SHOW_USAGE=y
CONFIG_LONG_OPTS=y

#
# Disable init/system services (not needed)
#
# CONFIG_INIT is not set
# CONFIG_CROND is not set
# CONFIG_KLOGD is not set
# CONFIG_SYSLOGD is not set

#
# Networking OFF (keep build small + no dependency issues)
#
# CONFIG_FEATURE_IPV6 is not set
# CONFIG_HTTPD is not set
# CONFIG_WGET is not set

#
# Archiving OFF (not needed for your toolset)
#
# CONFIG_TAR is not set
# CONFIG_GZIP is not set

#
# Editor OFF
#
# CONFIG_VI is not set
# CONFIG_AWK is not set
# CONFIG_SED is not set

#
# Process tools OFF (optional)
#
# CONFIG_PS is not set
# CONFIG_TOP is not set
